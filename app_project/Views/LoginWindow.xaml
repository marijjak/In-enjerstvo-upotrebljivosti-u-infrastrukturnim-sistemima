<Window x:Class="app_project.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Chanel CMS"
        Height="640" Width="460"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent">

    <Window.Resources>
        <Style x:Key="LabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#BFA181"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
            <Setter Property="Opacity" Value="0.85"/>
        </Style>

        <Style x:Key="FieldError" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#C0392B"/>
            <Setter Property="FontFamily" Value="Georgia"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Margin" Value="0,2,0,10"/>
            <Setter Property="Visibility" Value="Collapsed"/>
        </Style>

        <Style x:Key="InputStyle" TargetType="Control">
            <Setter Property="Background" Value="#0D0D0D"/>
            <Setter Property="Foreground" Value="#F5F5F5"/>
            <Setter Property="BorderBrush" Value="#333"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontFamily" Value="Georgia"/>
            <Setter Property="Padding" Value="10,4"/>
        </Style>

        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="#BFA181"/>
            <Setter Property="Foreground" Value="#000"/>
            <Setter Property="FontFamily" Value="Georgia"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Height" Value="44"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" Padding="16,8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#D4B896"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#A8896B"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SecondaryButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#555"/>
            <Setter Property="FontFamily" Value="Georgia"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Height" Value="44"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" Padding="16,8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="#BFA181"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CloseBtn" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#444"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Width" Value="32"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="#BFA181"/>
                                <Setter Property="Background" Value="#1A1A1A"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Border Margin="20">
            <Border.Effect>
                <DropShadowEffect Color="#000000" BlurRadius="60" ShadowDepth="0" Opacity="0.95"/>
            </Border.Effect>

            <Grid>
                <Grid.Clip>
                    <PathGeometry>
                        <PathFigure StartPoint="28,0" IsClosed="True">
                            <LineSegment Point="392,0"/>
                            <LineSegment Point="420,28"/>
                            <LineSegment Point="420,580"/>
                            <LineSegment Point="392,608"/>
                            <LineSegment Point="28,608"/>
                            <LineSegment Point="0,580"/>
                            <LineSegment Point="0,28"/>
                        </PathFigure>
                    </PathGeometry>
                </Grid.Clip>

                <Border Background="#080808"/>

                <Canvas>
                    <Path Stroke="#BFA181" StrokeThickness="1" Opacity="0.8">
                        <Path.Data>
                            <PathGeometry>
                                <PathFigure StartPoint="28,0" IsClosed="True">
                                    <LineSegment Point="392,0"/>
                                    <LineSegment Point="420,28"/>
                                    <LineSegment Point="420,580"/>
                                    <LineSegment Point="392,608"/>
                                    <LineSegment Point="28,608"/>
                                    <LineSegment Point="0,580"/>
                                    <LineSegment Point="0,28"/>
                                </PathFigure>
                            </PathGeometry>
                        </Path.Data>
                    </Path>
                    <Path Stroke="#BFA181" StrokeThickness="0.5" Opacity="0.25">
                        <Path.Data>
                            <PathGeometry>
                                <PathFigure StartPoint="34,6" IsClosed="True">
                                    <LineSegment Point="386,6"/>
                                    <LineSegment Point="414,34"/>
                                    <LineSegment Point="414,574"/>
                                    <LineSegment Point="386,602"/>
                                    <LineSegment Point="34,602"/>
                                    <LineSegment Point="6,574"/>
                                    <LineSegment Point="6,34"/>
                                </PathFigure>
                            </PathGeometry>
                        </Path.Data>
                    </Path>
                </Canvas>

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="44"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    
                    <Border Grid.Row="0"
                            Background="#050505"
                            BorderBrush="#1C1C1C"
                            BorderThickness="0,0,0,1"
                            MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                        <Grid>
                            <Button Style="{StaticResource CloseBtn}"
                                    HorizontalAlignment="Right"
                                    Margin="0,0,8,0"
                                    Click="WindowCloseButton_Click"
                                    ToolTip="Exit application">
                                <TextBlock Text="✕" FontSize="12"/>
                            </Button>
                        </Grid>
                    </Border>

                    
                    <StackPanel Grid.Row="1" VerticalAlignment="Center" Margin="58,0">

                        <StackPanel HorizontalAlignment="Center" Margin="0,0,0,28">
                            <Rectangle Height="1" Fill="#BFA181" Opacity="0.4" Width="60"/>
                            <Rectangle Height="1" Fill="#BFA181" Opacity="0.15" Width="60" Margin="0,3,0,0"/>
                        </StackPanel>

                        <Image Source="pack://application:,,,/Resources/Images/logo-Photoroom.png"
                               Width="80" Height="80"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,16" Opacity="0.9"/>

                        <TextBlock Text="CHANEL"
                                   FontFamily="Georgia" FontSize="34" FontWeight="Bold"
                                   Foreground="#BFA181" HorizontalAlignment="Center"
                                   Margin="0,0,0,4"/>

                        <Grid HorizontalAlignment="Center" Width="260" Margin="0,0,0,6">
                            <Rectangle Height="1" Fill="#BFA181" Opacity="0.6"/>
                        </Grid>

                        <TextBlock Text="I C O N I C   M O M E N T S"
                                   FontFamily="Segoe UI" FontSize="9"
                                   Foreground="#4A4A4A"
                                   HorizontalAlignment="Center"
                                   Margin="0,8,0,0"/>

                        <TextBlock Text="✦" FontSize="14" Foreground="#BFA181"
                                   HorizontalAlignment="Center" Opacity="0.5"
                                   Margin="0,10,0,36"/>

                        
                        <TextBlock Text="U S E R N A M E" Style="{StaticResource LabelStyle}"/>
                        <TextBox x:Name="UsernameTextBox"
                                 Style="{StaticResource InputStyle}"
                                 Margin="0,0,0,2"
                                 TextChanged="UsernameTextBox_TextChanged"
                                 ToolTip="Enter your username"/>
                        
                        <TextBlock x:Name="UsernameError"
                                   Style="{StaticResource FieldError}"/>

                        
                        <TextBlock Text="P A S S W O R D" Style="{StaticResource LabelStyle}"/>
                        <PasswordBox x:Name="PasswordBox"
                                     Style="{StaticResource InputStyle}"
                                     Margin="0,0,0,2"
                                     PasswordChanged="PasswordBox_PasswordChanged"
                                     ToolTip="Enter your password"/>
                        
                        <TextBlock x:Name="PasswordError"
                                   Style="{StaticResource FieldError}"/>

                        
                        <TextBlock x:Name="CredentialsError"
                                   Style="{StaticResource FieldError}"
                                   Margin="0,0,0,12"/>

                       
                        <Button x:Name="LoginButton"
                                Content="S I G N   I N"
                                Style="{StaticResource PrimaryButton}"
                                Margin="0,0,0,8"
                                Click="LoginButton_Click"
                                ToolTip="Sign in to your account"/>

                        <Button x:Name="ExitButton"
                                Content="E X I T"
                                Style="{StaticResource SecondaryButton}"
                                Click="ExitButton_Click"
                                ToolTip="Exit the application"/>

                        <StackPanel HorizontalAlignment="Center" Margin="0,32,0,0">
                            <Rectangle Height="1" Fill="#BFA181" Opacity="0.15" Width="60"/>
                            <Rectangle Height="1" Fill="#BFA181" Opacity="0.4" Width="60" Margin="0,3,0,0"/>
                        </StackPanel>

                    </StackPanel>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>
